# Puerto local del servidor
PORT=3000

# URL del frontend (para configurar CORS en producción)
# Ejemplo: https://mi-hotel.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Patrón Bridge: configuración SMTP para envío de recibos ────────────────
# Si no se definen, se usará Ethereal (cuenta de prueba automática para demos).
# La respuesta del endpoint /hotel/enviar-recibo incluirá una URL de vista
# previa donde puedes ver el correo generado sin necesitar SMTP real.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contraseña-de-aplicacion
# SMTP_FROM=noreply@aurumhotel.mx
